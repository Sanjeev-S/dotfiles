#!/usr/bin/env bash
set -euo pipefail

{{ if ne .op_token "" -}}
# Save 1Password token for shell sessions (needs chezmoi template variable)
install -d -m 700 "$HOME/.config/dotfiles"
(
  umask 077
  printf 'export OP_SERVICE_ACCOUNT_TOKEN=%q\n' {{ .op_token | quote }} > "$HOME/.config/dotfiles/.env"
)

# Source token and run the standalone secrets-refresh script
source "$HOME/.config/dotfiles/.env"
"$HOME/.local/bin/secrets-refresh"
{{ else -}}
echo "    NOTE: No 1Password token provided. Skipping secret caching."
echo "    To add later: chezmoi init"
{{ end -}}
