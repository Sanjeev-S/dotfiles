#!/usr/bin/env bash
set -euo pipefail

if [ -z "${OP_SERVICE_ACCOUNT_TOKEN:-}" ]; then
  echo "ERROR: OP_SERVICE_ACCOUNT_TOKEN not set." >&2
  echo "Source ~/.config/dotfiles/.env or run: chezmoi init" >&2
  exit 1
fi

if ! command -v op &>/dev/null; then
  echo "ERROR: op CLI not found in PATH." >&2
  exit 1
fi

echo "==> Refreshing secrets from 1Password..."

install -d -m 700 "$HOME/.config/dotfiles"
(
  umask 077
  SECRETS_FILE="$HOME/.config/dotfiles/secrets.sh"
  : > "$SECRETS_FILE"

  NTFY_TOPIC_VAL="$(op read 'op://Dotfiles/ntfy-topic/credential' --no-newline 2>/dev/null)" && {
    printf 'export NTFY_TOPIC=%q\n' "$NTFY_TOPIC_VAL" >> "$SECRETS_FILE"
    echo "    NTFY_TOPIC cached"
  } || echo "    WARNING: Failed to read NTFY_TOPIC from 1Password."

  OPENROUTER_API_KEY_VAL="$(op read 'op://Dotfiles/openrouter-api-key/credential' --no-newline 2>/dev/null)" && {
    printf 'export OPENROUTER_API_KEY=%q\n' "$OPENROUTER_API_KEY_VAL" >> "$SECRETS_FILE"
    echo "    OPENROUTER_API_KEY cached"
  } || echo "    WARNING: Failed to read OPENROUTER_API_KEY from 1Password."

  GITHUB_PAT_VAL="$(op read 'op://Dotfiles/github_personal_access_token/credential' --no-newline 2>/dev/null)" && {
    printf 'export GITHUB_PAT=%q\n' "$GITHUB_PAT_VAL" >> "$SECRETS_FILE"
    echo "    GITHUB_PAT cached"
    if command -v gh &>/dev/null; then
      printf '%s' "$GITHUB_PAT_VAL" | gh auth login --with-token 2>/dev/null \
        && echo "    GitHub CLI authenticated." \
        || echo "    WARNING: Failed to authenticate gh CLI."
    fi
  } || echo "    WARNING: Failed to read GITHUB_PAT from 1Password."

  echo "==> Secrets cached to ~/.config/dotfiles/secrets.sh"
)
