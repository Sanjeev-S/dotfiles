model = "gpt-5.4"
model_reasoning_effort = "xhigh"

{{ if or (eq .machine_type "linux-dev") (eq .machine_type "mac-dev") -}}
approval_policy = "never"
sandbox_mode = "danger-full-access"
{{ else if eq .machine_type "mac-personal" -}}
approval_policy = "never"
sandbox_mode = "danger-full-access"

[projects."{{ .chezmoi.homeDir }}/sanjeev"]
trust_level = "trusted"

[projects."{{ .chezmoi.homeDir }}/Downloads/Documents"]
trust_level = "trusted"

[projects."{{ .chezmoi.homeDir }}/dotfiles"]
trust_level = "trusted"
{{ end -}}

[tui]
status_line = ["model-with-reasoning", "current-dir", "context-used"]
